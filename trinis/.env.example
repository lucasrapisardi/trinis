# ── App ──────────────────────────────────────────
APP_ENV=development
APP_SECRET_KEY=change-me-to-a-long-random-string
APP_BASE_URL=http://localhost:8000

# ── Database ─────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://productsync:password@localhost:5432/productsync

# ── Redis ────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth (JWT) ───────────────────────────────────
JWT_SECRET_KEY=change-me-to-another-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Shopify (per-tenant, stored in DB — these are your app credentials) ──
SHOPIFY_APP_CLIENT_ID=your-shopify-app-client-id
SHOPIFY_APP_CLIENT_SECRET=your-shopify-app-client-secret
SHOPIFY_API_VERSION=2024-07
SHOPIFY_TOKEN_ENCRYPTION_KEY=gEsBCg27eJdJOVTMDfiYJzi4KAb_h0AK1RHS0AoZbrs=

# ── OpenAI ───────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Stripe ───────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_FREE_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_BUSINESS_PRICE_ID=price_...

# ── S3 / Storage ─────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=productsync-images
AWS_S3_REGION=us-east-1
